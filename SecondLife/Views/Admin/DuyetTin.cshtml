@model List<SecondLife.Models.Product>
@using SecondLife.Models
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Title = "Duyệt tin đăng";
    ViewBag.Tab = "tin";
    string loc = ViewBag.Loc as string ?? "ChoDuyet";
}

<style>
    .tab-loc {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
    }

        .tab-loc a {
            padding: 9px 18px;
            border-radius: 8px;
            text-decoration: none;
            font-size: .87rem;
            font-weight: 600;
            background: #132437;
            border: 1px solid #1e3a52;
            color: #8fa3b8;
        }

            .tab-loc a:hover {
                border-color: #2ec4b6;
                color: #2ec4b6;
            }

            .tab-loc a.on {
                background: #2ec4b6;
                border-color: #2ec4b6;
                color: #0d1b2a;
            }

    .sp-item {
        display: flex;
        gap: 16px;
        padding: 18px;
        border-bottom: 1px solid #1a2f45;
    }

        .sp-item:last-child {
            border-bottom: none;
        }

        .sp-item:hover {
            background: #16283d;
        }

    .sp-anh {
        width: 110px;
        height: 110px;
        border-radius: 10px;
        object-fit: cover;
        flex-shrink: 0;
        background: #0d1b2a;
        cursor: pointer;
    }

    .sp-noidung {
        flex: 1;
        min-width: 0;
    }

    .sp-tieude {
        font-weight: 600;
        font-size: 1rem;
        margin-bottom: 6px;
        color: #e0e6ed;
    }

    .sp-gia {
        color: #2ec4b6;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 8px;
    }

    .sp-mota {
        color: #8fa3b8;
        font-size: .85rem;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 10px;
    }

    .sp-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        font-size: .78rem;
        color: #5c7086;
    }

        .sp-meta span i {
            color: #2ec4b6;
            margin-right: 5px;
        }

    .sp-nut {
        display: flex;
        flex-direction: column;
        gap: 8px;
        justify-content: center;
        flex-shrink: 0;
    }

    .badge {
        padding: 4px 11px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .modal-nen {
        position: fixed;
        inset: 0;
        background: rgba(5,12,22,.8);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        backdrop-filter: blur(3px);
    }

        .modal-nen.hien {
            display: flex;
        }

    .modal-hop {
        background: #132437;
        border: 1px solid #1e3a52;
        border-radius: 14px;
        padding: 28px;
        width: 420px;
        max-width: 92vw;
        box-shadow: 0 20px 60px rgba(0,0,0,.55);
        animation: hienLen .2s ease;
    }

    @@keyframes hienLen {
        from {
            opacity: 0;
            transform: scale(.94);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .modal-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin: 0 auto 16px;
    }

    .modal-hop h3 {
        margin: 0 0 10px;
        text-align: center;
        font-size: 1.15rem;
        color: #e0e6ed;
    }

    .modal-hop p {
        margin: 0 0 22px;
        text-align: center;
        color: #8fa3b8;
        font-size: .9rem;
        line-height: 1.55;
    }

        .modal-hop p strong {
            color: #2ec4b6;
        }

    .modal-nut {
        display: flex;
        gap: 10px;
    }

        .modal-nut > * {
            flex: 1;
            text-align: center;
            padding: 11px;
        }

    .anh-to-nen {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.9);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 10000;
    }

        .anh-to-nen.hien {
            display: flex;
        }

        .anh-to-nen img {
            max-width: 88vw;
            max-height: 88vh;
            border-radius: 10px;
        }
</style>

<h2>Duyệt tin đăng</h2>

<div class="tab-loc">
    <a href="@Url.Action("DuyetTin", new { loc = "ChoDuyet" })" class="@(loc == "ChoDuyet" ? "on" : "")">Chờ duyệt</a>
    <a href="@Url.Action("DuyetTin", new { loc = "DaDuyet" })" class="@(loc == "DaDuyet" ? "on" : "")">Đã duyệt</a>
    <a href="@Url.Action("DuyetTin", new { loc = "TuChoi" })" class="@(loc == "TuChoi" ? "on" : "")">Từ chối</a>
    <a href="@Url.Action("DuyetTin", new { loc = "TatCa" })" class="@(loc == "TatCa" ? "on" : "")">Tất cả</a>
</div>

<div class="card" style="padding:0; overflow:hidden;">
    @if (Model.Any())
    {
        foreach (var sp in Model)
        {
            var anh = (sp.DanhSachAnh != null && sp.DanhSachAnh.Any())
                      ? Url.Content(sp.DanhSachAnh.First().DuongDanAnh)
                      : "/images/second-hand.png";
            string mau, chu;
            switch (sp.TrangThai)
            {
                case TrangThaiSanPham.DaDuyet: mau = "#2ec4b6"; chu = "Đang bán"; break;
                case TrangThaiSanPham.ChoDuyet: mau = "#f0b429"; chu = "Chờ duyệt"; break;
                case TrangThaiSanPham.DaBan: mau = "#6c8ebf"; chu = "Đã bán"; break;
                case TrangThaiSanPham.TuChoi: mau = "#ff6b6b"; chu = "Từ chối"; break;
                default: mau = "#4a5c6f"; chu = "Đã gỡ"; break;
            }

            <div class="sp-item">
                <img src="@anh" class="sp-anh" onclick="xemAnh('@anh')" alt="@sp.TieuDe" />

                <div class="sp-noidung">
                    <div style="display:flex; align-items:flex-start; gap:10px; margin-bottom:6px;">
                        <div class="sp-tieude" style="flex:1;">@sp.TieuDe</div>
                        <span class="badge" style="background:@mau; color:#0d1b2a;">@chu</span>
                    </div>
                    <div class="sp-gia">@sp.Gia.ToString("N0")đ</div>
                    <div class="sp-mota">@sp.MoTa</div>
                    <div class="sp-meta">
                        <span><i class="fa-solid fa-user"></i>@(sp.NguoiBan != null ? sp.NguoiBan.HoTen : "—")</span>
                        <span><i class="fa-solid fa-layer-group"></i>@(sp.DanhMuc != null ? sp.DanhMuc.TenDanhMuc : "Chưa phân loại")</span>
                        <span><i class="fa-solid fa-star"></i>@sp.TinhTrangPhanTram% mới</span>
                        <span><i class="fa-solid fa-clock"></i>@sp.NgayDang.ToString("dd/MM/yyyy HH:mm")</span>
                        <span><i class="fa-solid fa-images"></i>@(sp.DanhSachAnh != null ? sp.DanhSachAnh.Count : 0) ảnh</span>
                    </div>
                </div>

                <div class="sp-nut">
                    @if (sp.TrangThai == TrangThaiSanPham.ChoDuyet)
                    {
                        <button type="button" class="btn btn-xanh"
                                onclick="moDuyet(@sp.MaSanPham, '@Html.Raw(sp.TieuDe.Replace("'", "\\'"))')">
                            <i class="fa-solid fa-check"></i> Duyệt
                        </button>
                        <button type="button" class="btn btn-do"
                                onclick="moTuChoi(@sp.MaSanPham, '@Html.Raw(sp.TieuDe.Replace("'", "\\'"))')">
                            <i class="fa-solid fa-xmark"></i> Từ chối
                        </button>
                    }
                    else if (sp.TrangThai == TrangThaiSanPham.TuChoi)
                    {
                        <button type="button" class="btn btn-xanh"
                                onclick="moDuyet(@sp.MaSanPham, '@Html.Raw(sp.TieuDe.Replace("'", "\\'"))')">
                            <i class="fa-solid fa-rotate-left"></i> Duyệt lại
                        </button>
                    }
                    else if (sp.TrangThai == TrangThaiSanPham.DaDuyet)
                    {
                        <button type="button" class="btn btn-do"
                                onclick="moTuChoi(@sp.MaSanPham, '@Html.Raw(sp.TieuDe.Replace("'", "\\'"))')">
                            <i class="fa-solid fa-ban"></i> Gỡ tin
                        </button>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="rong">
            <i class="fa-solid fa-clipboard-check"></i>
            @if (loc == "ChoDuyet")
            {
                <text>Không có tin nào đang chờ duyệt.</text>
            }
            else
            {
                <text>Không có tin nào trong mục này.</text>
            }
        </div>
    }
</div>

<!-- MODAL DUYỆT -->
<div class="modal-nen" id="modalDuyet">
    <div class="modal-hop">
        <div class="modal-icon" style="background:rgba(46,196,182,.14); color:#2ec4b6;">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <h3>Xác nhận duyệt tin</h3>
        <p id="duyetNoiDung"></p>
        <form action="@Url.Action("DuyetSanPham", "Admin")" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="duyetId" />
            <div class="modal-nut">
                <button type="button" class="btn btn-xam" onclick="dong('modalDuyet')">Hủy bỏ</button>
                <button type="submit" class="btn btn-xanh">Duyệt tin</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL TỪ CHỐI -->
<div class="modal-nen" id="modalTuChoi">
    <div class="modal-hop">
        <div class="modal-icon" style="background:rgba(255,107,107,.14); color:#ff6b6b;">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h3>Từ chối tin đăng</h3>
        <p id="tuChoiNoiDung"></p>
        <form action="@Url.Action("TuChoiSanPham", "Admin")" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="tuChoiId" />
            <div class="modal-nut">
                <button type="button" class="btn btn-xam" onclick="dong('modalTuChoi')">Hủy bỏ</button>
                <button type="submit" class="btn btn-do">Xác nhận</button>
            </div>
        </form>
    </div>
</div>

<!-- XEM ẢNH TO -->
<div class="anh-to-nen" id="anhTo" onclick="this.classList.remove('hien')">
    <img id="anhToSrc" src="" alt="" />
</div>

<script>
    function moDuyet(id, ten) {
        document.getElementById("duyetId").value = id;
        document.getElementById("duyetNoiDung").innerHTML =
            "Duyệt tin <strong>" + ten + "</strong>? Tin sẽ hiển thị công khai trên trang chủ.";
        document.getElementById("modalDuyet").classList.add("hien");
    }
    function moTuChoi(id, ten) {
        document.getElementById("tuChoiId").value = id;
        document.getElementById("tuChoiNoiDung").innerHTML =
            "Từ chối tin <strong>" + ten + "</strong>? Tin sẽ bị ẩn khỏi trang chủ.";
        document.getElementById("modalTuChoi").classList.add("hien");
    }
    function dong(id) {
        document.getElementById(id).classList.remove("hien");
    }
    function xemAnh(src) {
        document.getElementById("anhToSrc").src = src;
        document.getElementById("anhTo").classList.add("hien");
    }

    ["modalDuyet", "modalTuChoi"].forEach(function (id) {
        document.getElementById(id).addEventListener("click", function (e) {
            if (e.target === this) this.classList.remove("hien");
        });
    });
    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
            document.querySelectorAll(".modal-nen, .anh-to-nen").forEach(function (m) {
                m.classList.remove("hien");
            });
        }
    });
</script>