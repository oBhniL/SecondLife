@using SecondLife.Models
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Title = "Tổng quan";
    ViewBag.Tab = "dash";
    var tinMoi = ViewBag.TinMoiNhat as List<Product> ?? new List<Product>();
}

<style>
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 16px;
        margin-bottom: 22px;
    }

    .stat-box {
        background: #132437;
        border: 1px solid #1e3a52;
        border-radius: 12px;
        padding: 20px;
    }

        .stat-box .ic {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            margin-bottom: 14px;
        }

        .stat-box .num {
            font-size: 1.9rem;
            font-weight: 700;
            color: #e0e6ed;
            line-height: 1;
        }

        .stat-box .lb {
            color: #8fa3b8;
            font-size: .82rem;
            margin-top: 7px;
        }

    .viec-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 16px;
        margin-bottom: 22px;
    }

    .viec-box {
        background: #132437;
        border: 1px solid #1e3a52;
        border-radius: 12px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        text-decoration: none;
        transition: .2s;
    }

        .viec-box:hover {
            border-color: #2ec4b6;
            transform: translateY(-2px);
        }

        .viec-box .ic {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .viec-box .txt {
            flex: 1;
        }

        .viec-box .t1 {
            color: #e0e6ed;
            font-weight: 600;
            font-size: .95rem;
        }

        .viec-box .t2 {
            color: #8fa3b8;
            font-size: .8rem;
            margin-top: 3px;
        }

        .viec-box .so {
            font-size: 1.6rem;
            font-weight: 700;
        }

    .badge {
        padding: 4px 11px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

    @@media (max-width: 900px) {
        .stat-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .viec-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<h2>Tổng quan</h2>

<div class="stat-grid">
    <div class="stat-box">
        <div class="ic" style="background:rgba(46,196,182,.14);color:#2ec4b6;"><i class="fa-solid fa-users"></i></div>
        <div class="num">@ViewBag.TongNguoiDung</div>
        <div class="lb">Thành viên</div>
    </div>
    <div class="stat-box">
        <div class="ic" style="background:rgba(108,142,191,.16);color:#6c8ebf;"><i class="fa-solid fa-box"></i></div>
        <div class="num">@ViewBag.TongSanPham</div>
        <div class="lb">Sản phẩm</div>
    </div>
    <div class="stat-box">
        <div class="ic" style="background:rgba(240,180,41,.14);color:#f0b429;"><i class="fa-solid fa-receipt"></i></div>
        <div class="num">@ViewBag.TongDonHang</div>
        <div class="lb">Đơn hàng</div>
    </div>
    <div class="stat-box">
        <div class="ic" style="background:rgba(46,196,182,.14);color:#2ec4b6;"><i class="fa-solid fa-sack-dollar"></i></div>
        <div class="num" style="font-size:1.35rem;">@(((decimal)ViewBag.DoanhThu).ToString("N0"))đ</div>
        <div class="lb">Doanh thu hoàn tất</div>
    </div>
</div>

<div class="viec-grid">
    <a href="@Url.Action("DuyetTin", "Admin")" class="viec-box">
        <div class="ic" style="background:rgba(240,180,41,.14);color:#f0b429;"><i class="fa-solid fa-clipboard-check"></i></div>
        <div class="txt">
            <div class="t1">Tin chờ duyệt</div>
            <div class="t2">Sản phẩm cần kiểm duyệt trước khi hiển thị</div>
        </div>
        <div class="so" style="color:@(ViewBag.ChoDuyetTin > 0 ? "#f0b429" : "#5c7086");">@ViewBag.ChoDuyetTin</div>
    </a>

    <a href="@Url.Action("DuyetXacThuc", "Admin")" class="viec-box">
        <div class="ic" style="background:rgba(255,107,107,.14);color:#ff6b6b;"><i class="fa-solid fa-id-card"></i></div>
        <div class="txt">
            <div class="t1">Hồ sơ chờ xác thực</div>
            <div class="t2">Người dùng nộp CCCD xin làm người bán</div>
        </div>
        <div class="so" style="color:@(ViewBag.ChoDuyetXacThuc > 0 ? "#ff6b6b" : "#5c7086");">@ViewBag.ChoDuyetXacThuc</div>
    </a>
</div>

<div class="card" style="padding:0; overflow:hidden;">
    <div style="padding:18px 20px; border-bottom:1px solid #1e3a52; display:flex; justify-content:space-between; align-items:center;">
        <strong style="color:#2ec4b6;">Tin đăng mới nhất</strong>
        <a href="@Url.Action("DuyetTin", "Admin", new { loc = "TatCa" })" style="color:#8fa3b8; text-decoration:none; font-size:.83rem;">Xem tất cả →</a>
    </div>

    @if (tinMoi.Any())
    {
        <table class="tbl">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th style="width:170px;">Người bán</th>
                    <th style="width:120px;">Giá</th>
                    <th style="width:115px;">Trạng thái</th>
                    <th style="width:105px;">Ngày đăng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sp in tinMoi)
                {
                    string mau, chu;
                    switch (sp.TrangThai)
                    {
                        case TrangThaiSanPham.DaDuyet: mau = "#2ec4b6"; chu = "Đang bán"; break;
                        case TrangThaiSanPham.ChoDuyet: mau = "#f0b429"; chu = "Chờ duyệt"; break;
                        case TrangThaiSanPham.DaBan: mau = "#6c8ebf"; chu = "Đã bán"; break;
                        case TrangThaiSanPham.TuChoi: mau = "#ff6b6b"; chu = "Từ chối"; break;
                        default: mau = "#4a5c6f"; chu = "Đã gỡ"; break;
                    }
                    <tr>
                        <td style="max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@sp.TieuDe</td>
                        <td style="color:#8fa3b8;">@(sp.NguoiBan != null ? sp.NguoiBan.HoTen : "—")</td>
                        <td style="color:#2ec4b6; font-weight:600;">@sp.Gia.ToString("N0")đ</td>
                        <td><span class="badge" style="background:@mau; color:#0d1b2a;">@chu</span></td>
                        <td style="color:#5c7086; font-size:13px;">@sp.NgayDang.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="rong">
            <i class="fa-solid fa-inbox"></i>
            Chưa có tin đăng nào trong hệ thống.
        </div>
    }
</div>