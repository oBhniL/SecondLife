    <script src="/Scripts/script.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btnLeft = document.getElementById("btn-slide-left");
            const btnRight = document.getElementById("btn-slide-right");
            const carousel = document.getElementById("carousel-new-products");

            if (btnLeft && btnRight && carousel)
            {
                const scrollAmount = 300;

                btnLeft.addEventListener("click", function (e) {
                    e.preventDefault();
                    carousel.scrollBy({
                        left: -scrollAmount,
                        behavior: "smooth"
                    });
                });

                btnRight.addEventListener("click", function (e) {
                    e.preventDefault();
                    carousel.scrollBy({
                        left: scrollAmount,
                        behavior: "smooth"
                    });
                });
            } else {
                console.error("Không tìm thấy các phần tử Slider, check lại ID!");
            }
        });

        function submitOrder() {
            alert("Đã nhận yêu cầu gửi hệ thống của bạn!");
        }
    </script>
