@model List<SecondLife.Models.Product>
@{
    ViewBag.Title = "Trang chủ";
    var danhMucs = ViewBag.DanhMucs as List<SecondLife.Models.Category> ?? new List<SecondLife.Models.Category>();
}

<!-- BANNER -->
<!-- SLIDER BANNER -->
<section class="slider" style="margin:24px 0;">
    <div class="slides">
        <div class="slide active" style="background:linear-gradient(135deg,#14a89c,#0f8a80);">
            <div class="slide-text">
                <span class="slide-tag"><i class="fa-solid fa-leaf"></i> Mua sắm thông minh</span>
                <h1>Cũ với người,<br>mới với bạn</h1>
                <p>Khám phá hàng ngàn món đồ chất lượng với giá cực kỳ ưu đãi.</p>
                <a href="@Url.Action("Index", "Product")" class="btn" style="background:#fff; color:#14a89c;">Khám phá ngay</a>
            </div>
        </div>

        <div class="slides">
            <div class="slide active">
                <img src="~/Images/Banner1.jpg" alt="Banner 1" />
            </div>
            <div class="slide">
                <img src="~/Images/Banner2.jpg" alt="Banner 2" />
            </div>
            <div class="slide">
                <img src="~/Images/Banner3.jpg" alt="Banner 3" />
            </div>
        </div>

        <div class="slide" style="background:linear-gradient(135deg,#0891b2,#075985);">
            <div class="slide-text">
                <span class="slide-tag"><i class="fa-solid fa-shield-halved"></i> Giao dịch an toàn</span>
                <h1>Bán đồ cũ,<br>thêm thu nhập</h1>
                <p>Đăng tin miễn phí, người bán được xác thực CCCD.</p>
                <a href="@Url.Action("DangTin", "Product")" class="btn" style="background:#fff; color:#0891b2;">Đăng tin bán</a>
            </div>
        </div>
    </div>

    <button class="slider-btn prev" onclick="chuyenSlide(-1)"><i class="fa-solid fa-chevron-left"></i></button>
    <button class="slider-btn next" onclick="chuyenSlide(1)"><i class="fa-solid fa-chevron-right"></i></button>

    <div class="slider-dots">
        <span class="dot active" onclick="chonSlide(0)"></span>
        <span class="dot" onclick="chonSlide(1)"></span>
        <span class="dot" onclick="chonSlide(2)"></span>
    </div>
</section>

<style>
    .slider {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
    }

    .slides {
        position: relative;
        height: 320px;
    }

    .slide {
        position: absolute;
        inset: 0;
        padding: 48px 40px;
        color: #fff;
        display: flex;
        align-items: center;
        opacity: 0;
        transition: opacity .6s ease;
    }

        .slide.active {
            opacity: 1;
        }

    .slide-text {
        max-width: 560px;
    }

    .slide-tag {
        background: rgba(255,255,255,.2);
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 13px;
    }

    .slide-text h1 {
        font-size: 38px;
        margin: 16px 0 12px;
        line-height: 1.2;
    }

    .slide-text p {
        font-size: 16px;
        opacity: .95;
        margin-bottom: 24px;
    }

    .slider-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,.25);
        color: #fff;
        border: none;
        width: 42px;
        height: 42px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 16px;
    }

        .slider-btn:hover {
            background: rgba(255,255,255,.4);
        }

        .slider-btn.prev {
            left: 16px;
        }

        .slider-btn.next {
            right: 16px;
        }

    .slider-dots {
        position: absolute;
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 8px;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255,255,255,.5);
        cursor: pointer;
    }

        .dot.active {
            background: #fff;
            width: 26px;
            border-radius: 6px;
        }

    @@media (max-width: 700px) {
        .slides {
            height: 280px;
        }

        .slide-text h1 {
            font-size: 28px;
        }
    }
</style>

<script>
    var slideHienTai = 0;
    var cacSlide = document.querySelectorAll(".slide");
    var cacDot = document.querySelectorAll(".dot");

    function hienThi(n) {
        cacSlide.forEach(function (s) { s.classList.remove("active"); });
        cacDot.forEach(function (d) { d.classList.remove("active"); });
        cacSlide[n].classList.add("active");
        cacDot[n].classList.add("active");
    }

    function chuyenSlide(huong) {
        slideHienTai = (slideHienTai + huong + cacSlide.length) % cacSlide.length;
        hienThi(slideHienTai);
    }

    function chonSlide(n) {
        slideHienTai = n;
        hienThi(slideHienTai);
    }

    // Tự chạy mỗi 4 giây
    setInterval(function () { chuyenSlide(1); }, 4000);
</script>

<!-- THỐNG KÊ -->
<section style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:36px;">
    <div style="background:#fff; border:1px solid #eceff1; border-radius:12px; padding:22px; text-align:center;">
        <div style="font-size:28px; font-weight:700; color:#2ec4b6;">@ViewBag.TongSanPham</div>
        <div style="color:#6b7280; font-size:14px;">Sản phẩm đang bán</div>
    </div>
    <div style="background:#fff; border:1px solid #eceff1; border-radius:12px; padding:22px; text-align:center;">
        <div style="font-size:28px; font-weight:700; color:#2ec4b6;">@ViewBag.TongNguoiDung</div>
        <div style="color:#6b7280; font-size:14px;">Thành viên</div>
    </div>
    <div style="background:#fff; border:1px solid #eceff1; border-radius:12px; padding:22px; text-align:center;">
        <div style="font-size:28px; font-weight:700; color:#2ec4b6;">@ViewBag.TongDonHang</div>
        <div style="color:#6b7280; font-size:14px;">Đơn hàng thành công</div>
    </div>
</section>

<!-- DANH MỤC -->
@if (danhMucs.Any())
{
    <div class="sl-title"><h1>Danh mục sản phẩm</h1></div>
    <div style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:36px;">
        @foreach (var dm in danhMucs)
        {
            <a href="@Url.Action("Index", "Product", new { danhMuc = dm.MaDanhMuc })"
               style="background:#fff; border:1px solid #eceff1; padding:10px 18px; border-radius:20px; font-size:14px; color:#444;">
                @dm.TenDanhMuc
            </a>
        }
    </div>
}

<!-- SẢN PHẨM MỚI -->
<div class="sl-title" style="display:flex; justify-content:space-between; align-items:center;">
    <h1>Sản phẩm mới đăng</h1>
    <a href="@Url.Action("Index", "Product")" style="color:#2ec4b6; font-size:14px;">Xem tất cả →</a>
</div>

@if (Model.Any())
{
    <div class="sl-grid">
        @foreach (var sp in Model)
        {
            <a href="@Url.Action("ChiTiet", "Product", new { id = sp.MaSanPham })" class="sl-card">
                <div class="sl-card-img">
                    @if (sp.DanhSachAnh != null && sp.DanhSachAnh.Count > 0)
                    {
                        <img src="@Url.Content(sp.DanhSachAnh.First().DuongDanAnh)" alt="@sp.TieuDe" />
                    }
                    else
                    {
                        <img src="~/images/second-hand.png" alt="No image" />
                    }
                    <span class="sl-badge">@sp.TinhTrangPhanTram% New</span>
                </div>
                <div class="sl-card-body">
                    <h3>@sp.TieuDe</h3>
                    <span class="sl-cat">@(sp.DanhMuc != null ? sp.DanhMuc.TenDanhMuc : "")</span>
                    <span class="sl-price">@sp.Gia.ToString("#,##0")đ</span>
                </div>
            </a>
        }
    </div>
}
else
{
    <p style="text-align:center; color:#9ca3af; padding:40px 0;">Chưa có sản phẩm nào. Hãy là người đăng tin đầu tiên!</p>
}

<section style="margin:50px 0;">
    <div class="sl-title" style="text-align:center;"><h1>Tại sao chọn SecondLife?</h1></div>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px;">
        <div style="background:#fff; border:1px solid #eceff1; border-radius:12px; padding:24px; text-align:center;">
            <i class="fa-solid fa-magnifying-glass" style="font-size:28px; color:#2ec4b6;"></i>
            <h3 style="margin:12px 0 8px;">Định giá minh bạch</h3>
            <p style="color:#6b7280; font-size:14px;">Sản phẩm được kiểm duyệt, giá đúng với giá trị thực.</p>
        </div>
        <div style="background:#fff; border:1px solid #eceff1; border-radius:12px; padding:24px; text-align:center;">
            <i class="fa-solid fa-wallet" style="font-size:28px; color:#2ec4b6;"></i>
            <h3 style="margin:12px 0 8px;">Tiết kiệm tối đa</h3>
            <p style="color:#6b7280; font-size:14px;">Sở hữu đồ chất lượng với chi phí giảm 50–80% so với mua mới.</p>
        </div>
        <div style="background:#fff; border:1px solid #eceff1; border-radius:12px; padding:24px; text-align:center;">
            <i class="fa-solid fa-shield-halved" style="font-size:28px; color:#2ec4b6;"></i>
            <h3 style="margin:12px 0 8px;">Giao dịch an toàn</h3>
            <p style="color:#6b7280; font-size:14px;">Người bán được xác thực CCCD, mua bán yên tâm.</p>
        </div>
    </div>
</section>