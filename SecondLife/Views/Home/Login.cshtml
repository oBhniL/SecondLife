@model SecondLife.Models.DangNhapViewModel
@{
    ViewBag.Title = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập - SecondLife</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/Content/secondlife.css?v=3" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 40px 20px;
        }

        .auth-box {
            background: #fff;
            border: 1px solid #eceff1;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 10px 40px rgba(0,0,0,.08);
        }

        .auth-logo {
            text-align: center;
            font-size: 22px;
            font-weight: 800;
            color: #2ec4b6;
            margin-bottom: 8px;
        }

        .auth-box h2 {
            text-align: center;
            font-size: 24px;
            color: #111;
            margin-bottom: 4px;
        }

        .auth-sub {
            text-align: center;
            color: #9ca3af;
            font-size: 14px;
            margin-bottom: 26px;
        }

        .text-danger {
            color: #ef4444;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .row-opt {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 20px;
        }

        .switch {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: #6b7280;
        }

            .switch a {
                color: #2ec4b6;
                font-weight: 600;
            }
    </style>
</head>
<body>
    <div class="auth-box">
        <div class="auth-logo"><i class="fa-solid fa-recycle"></i> SecondLife</div>
        <h2>Đăng nhập</h2>
        <p class="auth-sub">Chào mừng bạn quay lại</p>

        @using (Html.BeginForm("Login", "Home", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="group">
                @Html.LabelFor(m => m.Email)
                @Html.TextBoxFor(m => m.Email, new { style = "width:100%; padding:11px 14px; border:1px solid #d1d5db; border-radius:8px;" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <div class="group">
                @Html.LabelFor(m => m.MatKhau)
                @Html.PasswordFor(m => m.MatKhau, new { style = "width:100%; padding:11px 14px; border:1px solid #d1d5db; border-radius:8px;" })
                @Html.ValidationMessageFor(m => m.MatKhau, "", new { @class = "text-danger" })
            </div>

            <div class="row-opt">
                <label>@Html.CheckBoxFor(m => m.GhiNho) Ghi nhớ đăng nhập</label>
                <a href="#" style="color:#2ec4b6;">Quên mật khẩu?</a>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Đăng nhập</button>
        }

        <div class="switch">
            Chưa có tài khoản? <a href="@Url.Action("Register", "Home")">Đăng ký ngay</a>
        </div>
    </div>
</body>
</html>