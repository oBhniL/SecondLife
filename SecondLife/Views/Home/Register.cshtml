@model SecondLife.Models.DangKyViewModel
@{
    ViewBag.Title = "Đăng Ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng Ký - SecondLife</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Arial, sans-serif;
        }

        body {
            background: #0d1b2a;
            color: #ffffff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .auth-container {
            background: #13263c;
            border: 1px solid #1f3a54;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
        }

        .logo {
            text-align: center;
            margin-bottom: 24px;
            font-size: 22px;
            font-weight: 800;
        }

            .logo span {
                color: #2dd4bf;
            }

        h2 {
            text-align: center;
            font-size: 26px;
            margin-bottom: 6px;
        }

        .subtitle {
            text-align: center;
            color: #9fb3c8;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            font-size: 13px;
            color: #9fb3c8;
            margin-bottom: 6px;
        }

        input {
            width: 100%;
            padding: 12px 14px;
            border-radius: 8px;
            border: 1px solid #1f3a54;
            background: #0d1b2a;
            color: #fff;
            font-size: 14px;
            outline: none;
        }

            input:focus {
                border-color: #2dd4bf;
            }

        .text-danger {
            color: #ff6b6b;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .btn-submit {
            width: 100%;
            padding: 13px;
            border: none;
            border-radius: 999px;
            background: #2dd4bf;
            color: #0d1b2a;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.2s;
        }

            .btn-submit:hover {
                background: #25b8a5;
            }

        .switch-link {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: #9fb3c8;
        }

            .switch-link a {
                color: #2dd4bf;
                text-decoration: none;
                font-weight: 600;
            }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="logo">2HAND <span>RetroLife</span></div>
        <h2>Tạo Tài Khoản</h2>
        <p class="subtitle">Tham gia cộng đồng mua bán đồ cũ uy tín</p>

        @using (Html.BeginForm("Register", "Home", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group">
                @Html.LabelFor(m => m.HoTen)
                @Html.TextBoxFor(m => m.HoTen)
                @Html.ValidationMessageFor(m => m.HoTen, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Email)
                @Html.TextBoxFor(m => m.Email)
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.SoDienThoai)
                @Html.TextBoxFor(m => m.SoDienThoai)
                @Html.ValidationMessageFor(m => m.SoDienThoai, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.MatKhau)
                @Html.PasswordFor(m => m.MatKhau)
                @Html.ValidationMessageFor(m => m.MatKhau, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.XacNhanMatKhau)
                @Html.PasswordFor(m => m.XacNhanMatKhau)
                @Html.ValidationMessageFor(m => m.XacNhanMatKhau, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn-submit">Đăng Ký</button>
        }

        <div class="switch-link">
            Đã có tài khoản? <a href="@Url.Action("Login", "Home")">Đăng nhập ngay</a>
        </div>
    </div>
</body>
</html>