@model SecondLife.Models.Product
@{
    ViewBag.Title = "Đặt hàng";
}

<div class="sl-title">
    <h1>Xác nhận đặt hàng</h1>
</div>

@if (TempData["Loi"] != null)
{
    <div class="sl-alert sl-alert-err" style="max-width:640px; margin:0 auto 16px;">@TempData["Loi"]</div>
}

<div class="sl-form">
    <!-- Thông tin sản phẩm -->
    <div style="display:flex; gap:14px; align-items:center; background:#f8f9fa; padding:14px; border-radius:10px; margin-bottom:22px;">
        @if (Model.DanhSachAnh != null && Model.DanhSachAnh.Count > 0)
        {
            <img src="@Url.Content(Model.DanhSachAnh.First().DuongDanAnh)" alt="@Model.TieuDe"
                 style="width:80px; height:80px; object-fit:cover; border-radius:8px;" />
        }
        <div>
            <h3 style="color:#111;">@Model.TieuDe</h3>
            <p style="color:#ef4444; font-weight:700; font-size:20px; margin-top:4px;">@Model.Gia.ToString("#,##0")đ</p>
        </div>
    </div>

    @using (Html.BeginForm("DatHang", "Order", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" name="MaSanPham" value="@Model.MaSanPham" />

        <div class="group">
            <label>Địa chỉ giao hàng</label>
            <input type="text" name="DiaChiGiaoHang" placeholder="Số nhà, đường, phường, quận, tỉnh/thành" required />
        </div>

        <div class="group">
            <label>Số điện thoại liên hệ</label>
            <input type="tel" name="SoDienThoaiLienHe" placeholder="Nhập số điện thoại" required />
        </div>

        <div style="text-align:center; margin:18px 0; font-size:16px;">
            Tổng thanh toán:
            <strong style="color:#ef4444; font-size:22px;">@Model.Gia.ToString("#,##0")đ</strong>
        </div>

        <button type="submit" class="btn btn-primary btn-block"><i class="fa-solid fa-check"></i> Xác nhận đặt hàng</button>
    }
</div>