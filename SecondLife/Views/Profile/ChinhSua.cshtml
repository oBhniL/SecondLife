@model SecondLife.Models.ApplicationUser
@{
    Layout = "~/Views/Shared/_LayoutProfile.cshtml";
    ViewBag.Title = "Chỉnh sửa thông tin";
    ViewBag.Tab = "info";
    ViewBag.HoTen = Model.HoTen;
    ViewBag.AnhDaiDien = Model.AnhDaiDien;
}

<h2 style="color:#2ec4b6;">Chỉnh sửa thông tin</h2>

@if (TempData["Loi"] != null)
{
    <div class="sl-alert sl-alert-err">@TempData["Loi"]</div>
}

@using (Html.BeginForm("ChinhSua", "Profile", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div style="display:flex; align-items:center; gap:20px; margin-bottom:24px;">
        <div class="pf-avatar" id="anhXemTruoc" style="width:96px; height:96px; font-size:36px;">
            @if (!string.IsNullOrEmpty(Model.AnhDaiDien))
            {
                <img src="@Url.Content(Model.AnhDaiDien)" alt="avatar" />
            }
            else
            {
                @Model.HoTen.Substring(0, 1).ToUpper()
            }
        </div>
        <div>
            <label style="font-weight:600; display:block; margin-bottom:8px;">Ảnh đại diện</label>
            <input type="file" name="AnhMoi" id="inputAnh" accept=".jpg,.jpeg,.png" />
            <div style="color:#9ca3af; font-size:12px; margin-top:6px;">JPG hoặc PNG, tối đa 2MB</div>
        </div>
    </div>

    <div class="sl-row">
        <div class="group">
            <label>Họ và tên</label>
            <input type="text" name="HoTen" value="@Model.HoTen" required maxlength="100"
                   style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px;" />
        </div>
        <div class="group">
            <label>Ngày sinh</label>
            <input type="date" name="NgaySinh" value="@(Model.NgaySinh.HasValue ? Model.NgaySinh.Value.ToString("yyyy-MM-dd") : "")"
                   style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px;" />
        </div>
    </div>

    <div class="sl-row">
        <div class="group">
            <label>Email</label>
            <input type="email" name="Email" value="@Model.Email" required
                   style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px;" />
        </div>
        <div class="group">
            <label>Số điện thoại</label>
            <input type="tel" name="PhoneNumber" value="@Model.PhoneNumber" maxlength="15"
                   style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px;" />
        </div>
    </div>

    <div class="group">
        <label>Số CCCD</label>
        <input type="text" value="@(string.IsNullOrEmpty(Model.SoCCCD) ? "Chưa cập nhật" : Model.SoCCCD)" disabled
               style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px; opacity:.55;" />
        <div style="color:#9ca3af; font-size:12px; margin-top:6px;">CCCD chỉ thay đổi được qua trang Xác thực người bán</div>
    </div>

    <div style="margin-top:24px; display:flex; gap:12px; align-items:center;">
        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        <a href="@Url.Action("Index", "Profile")" class="btn btn-outline">Hủy</a>
        <a href="@Url.Action("DoiMatKhau", "Profile")" class="btn btn-outline" style="margin-left:auto;">Đổi mật khẩu</a>
    </div>
}

<script>
    document.getElementById("inputAnh").addEventListener("change", function (e) {
        var file = e.target.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function (ev) {
            document.getElementById("anhXemTruoc").innerHTML = '<img src="' + ev.target.result + '" alt="preview" />';
        };
        reader.readAsDataURL(file);
    });
</script>