@{
    Layout = "~/Views/Shared/_LayoutProfile.cshtml";
    ViewBag.Title = "Đổi mật khẩu";
    ViewBag.Tab = "info";
}

<h2 style="color:#2ec4b6;">Đổi mật khẩu</h2>

@if (TempData["Loi"] != null)
{
    <div class="sl-alert sl-alert-err" style="max-width:420px;">@TempData["Loi"]</div>
}

@using (Html.BeginForm("DoiMatKhau", "Profile", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="group" style="max-width:420px;">
        <label style="font-weight:600;">Mật khẩu hiện tại</label>
        <input type="password" name="MatKhauCu" required style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px;" />
    </div>
    <div class="group" style="max-width:420px;">
        <label style="font-weight:600;">Mật khẩu mới</label>
        <input type="password" name="MatKhauMoi" required minlength="6" style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px;" />
    </div>
    <div class="group" style="max-width:420px;">
        <label style="font-weight:600;">Xác nhận mật khẩu mới</label>
        <input type="password" name="XacNhanMatKhau" required minlength="6" style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px;" />
    </div>

    <div style="margin-top:20px; display:flex; gap:12px;">
        <button type="submit" class="btn btn-primary">Đổi mật khẩu</button>
        <a href="@Url.Action("Index", "Profile")" class="btn btn-outline">Hủy</a>
    </div>
}