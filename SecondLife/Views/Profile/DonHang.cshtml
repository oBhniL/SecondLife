@model List<SecondLife.Models.Order>
@using SecondLife.Models
@{
    Layout = "~/Views/Shared/_LayoutProfile.cshtml";
    ViewBag.Title = "Đơn hàng của tôi";
    ViewBag.Tab = "don";
    ViewBag.HoTen = Model.HoTen;
}

<h2 style="color:#2ec4b6;">Đơn hàng của tôi (@Model.Count)</h2>

@if (!Model.Any())
{
    <p style="color:#9ca3af;">Bạn chưa có đơn hàng nào.</p>
}
else
{
    foreach (var dh in Model)
    {
        string mau = dh.TrangThai == TrangThaiDonHang.HoanTat ? "#2ec4b6"
                   : dh.TrangThai == TrangThaiDonHang.DangGiao ? "#6c8ebf"
                   : dh.TrangThai == TrangThaiDonHang.ChoXacNhan ? "#f0b429" : "#ef4444";
        string chu = dh.TrangThai == TrangThaiDonHang.HoanTat ? "Hoàn tất"
                   : dh.TrangThai == TrangThaiDonHang.DangGiao ? "Đang giao"
                   : dh.TrangThai == TrangThaiDonHang.ChoXacNhan ? "Chờ xác nhận" : "Đã hủy";

        <div style="background:#f8f9fa; border-radius:10px; padding:16px; margin-bottom:12px;">
            <div style="display:flex; justify-content:space-between;">
                <div style="font-weight:600;">Đơn #@dh.MaDonHang</div>
                <span style="background:@mau; color:#fff; padding:4px 12px; border-radius:20px; font-size:12px;">@chu</span>
            </div>
            <div style="font-size:13px; color:#9ca3af; margin-top:8px;">@dh.NgayDatHang.ToString("dd/MM/yyyy HH:mm") · @dh.DiaChiGiaoHang</div>
            <div style="color:#ef4444; font-weight:700; margin-top:8px;">Tổng: @dh.TongTien.ToString("N0") đ</div>
        </div>
    }
}