@model SecondLife.Models.ApplicationUser
@using SecondLife.Models
@{
    Layout = "~/Views/Shared/_LayoutProfile.cshtml";
    ViewBag.Title = "Thông tin cá nhân";
    ViewBag.Tab = "info";
    ViewBag.HoTen = Model.HoTen;
    ViewBag.AnhDaiDien = Model.AnhDaiDien;
    var tinCuaToi = ViewBag.TinCuaToi as List<Product> ?? new List<Product>();
    int tongTin = ViewBag.TongTin ?? 0;
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
    <h2 style="color:#2ec4b6; margin:0;">Thông tin cá nhân</h2>
    <a href="@Url.Action("ChinhSua", "Profile")" class="btn btn-primary"><i class="fa-solid fa-pen"></i> Chỉnh sửa</a>
</div>

<table style="width:100%; border-collapse:collapse;">
    <tr><td style="padding:12px 0; color:#9ca3af; width:180px;">Họ tên</td><td>@Model.HoTen</td></tr>
    <tr><td style="padding:12px 0; color:#9ca3af;">Email</td><td>@Model.Email</td></tr>
    <tr><td style="padding:12px 0; color:#9ca3af;">Số điện thoại</td><td>@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)</td></tr>
    <tr><td style="padding:12px 0; color:#9ca3af;">Số CCCD</td><td>@(string.IsNullOrEmpty(Model.SoCCCD) ? "Chưa cập nhật" : Model.SoCCCD)</td></tr>
    <tr><td style="padding:12px 0; color:#9ca3af;">Ngày sinh</td><td>@(Model.NgaySinh.HasValue ? Model.NgaySinh.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")</td></tr>
    <tr><td style="padding:12px 0; color:#9ca3af;">Ngày tham gia</td><td>@Model.NgayTao.ToString("dd/MM/yyyy")</td></tr>
    <tr>
        <td style="padding:12px 0; color:#9ca3af;">Trạng thái bán hàng</td>
        <td>
            @switch (Model.TinhTrangXacThuc)
            {
                case TrangThaiXacThuc.DaDuyet:
                    <span style="background:#ecfdf5; color:#047857; padding:4px 12px; border-radius:20px; font-size:13px;">Đã xác thực</span>
                    break;
                case TrangThaiXacThuc.DangCho:
                    <span style="background:#fef3c7; color:#b45309; padding:4px 12px; border-radius:20px; font-size:13px;">Đang chờ duyệt</span>
                    break;
                case TrangThaiXacThuc.TuChoi:
                    <span style="background:#fef2f2; color:#b91c1c; padding:4px 12px; border-radius:20px; font-size:13px;">Bị từ chối</span>
                    break;
                default:
                    <span style="background:#f3f4f6; color:#6b7280; padding:4px 12px; border-radius:20px; font-size:13px;">Chưa nộp hồ sơ</span>
                    break;
            }
        </td>
    </tr>
</table>

<div style="margin-top:32px; padding-top:24px; border-top:1px solid #eceff1;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
        <h3 style="color:#2ec4b6; margin:0;">Tin đã đăng (@tongTin)</h3>
        @if (tongTin > 6)
        {
            <a href="@Url.Action("TinDaDang", "Profile")" style="color:#9ca3af; font-size:14px;">Xem tất cả →</a>
        }
    </div>

    @if (tinCuaToi.Any())
    {
        <div class="sl-grid" style="grid-template-columns:repeat(3,1fr);">
            @foreach (var sp in tinCuaToi)
            {
                var anh = (sp.DanhSachAnh != null && sp.DanhSachAnh.Any())
                          ? Url.Content(sp.DanhSachAnh.First().DuongDanAnh) : "/images/second-hand.png";
                string mau, chu;
                switch (sp.TrangThai)
                {
                    case TrangThaiSanPham.DaDuyet: mau = "#2ec4b6"; chu = "Đang bán"; break;
                    case TrangThaiSanPham.ChoDuyet: mau = "#f0b429"; chu = "Chờ duyệt"; break;
                    case TrangThaiSanPham.DaBan: mau = "#6c8ebf"; chu = "Đã bán"; break;
                    case TrangThaiSanPham.TuChoi: mau = "#ef4444"; chu = "Bị từ chối"; break;
                    default: mau = "#9ca3af"; chu = "Đã gỡ"; break;
                }
                <a href="@Url.Action("ChiTiet", "Product", new { id = sp.MaSanPham })" class="sl-card">
                    <div class="sl-card-img"><img src="@anh" alt="@sp.TieuDe" /></div>
                    <div class="sl-card-body">
                        <h3>@sp.TieuDe</h3>
                        <span class="sl-price">@sp.Gia.ToString("N0")đ</span>
                        <span style="align-self:flex-start; background:@mau; color:#fff; padding:3px 10px; border-radius:20px; font-size:12px;">@chu</span>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div style="text-align:center; padding:40px 20px; color:#9ca3af;">
            <i class="fa-solid fa-box-open" style="font-size:36px; color:#2ec4b6; display:block; margin-bottom:12px;"></i>
            Bạn chưa đăng tin nào.<br />
            <a href="@Url.Action("DangTin", "Product")" class="btn btn-primary" style="margin-top:12px;">Đăng tin đầu tiên</a>
        </div>
    }
</div>