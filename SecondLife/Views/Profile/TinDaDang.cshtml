@model List<SecondLife.Models.Product>
@using SecondLife.Models
@{
    Layout = "~/Views/Shared/_LayoutProfile.cshtml";
    ViewBag.Title = "Tin đã đăng";
    ViewBag.Tab = "tin";
    ViewBag.HoTen = User.Identity.Name;
}

<h2 style="color:#2ec4b6;">Tin đã đăng (@Model.Count)</h2>

@if (!Model.Any())
{
    <p style="color:#9ca3af;">Bạn chưa đăng tin nào.</p>
}
else
{
    foreach (var sp in Model)
    {
        string mau = sp.TrangThai == TrangThaiSanPham.DaDuyet ? "#2ec4b6"
                   : sp.TrangThai == TrangThaiSanPham.ChoDuyet ? "#f0b429"
                   : sp.TrangThai == TrangThaiSanPham.DaBan ? "#6c8ebf" : "#ef4444";
        string chu = sp.TrangThai == TrangThaiSanPham.DaDuyet ? "Đang bán"
                   : sp.TrangThai == TrangThaiSanPham.ChoDuyet ? "Chờ duyệt"
                   : sp.TrangThai == TrangThaiSanPham.DaBan ? "Đã bán"
                   : sp.TrangThai == TrangThaiSanPham.TuChoi ? "Bị từ chối" : "Đã gỡ";

        <div style="display:flex; gap:16px; background:#f8f9fa; border-radius:10px; padding:14px; margin-bottom:12px; align-items:center;">
            <img src="@(sp.DanhSachAnh != null && sp.DanhSachAnh.Any() ? Url.Content(sp.DanhSachAnh.First().DuongDanAnh) : Url.Content("~/Images/second-hand.png"))"
                 style="width:88px; height:88px; object-fit:cover; border-radius:8px;" />
            <div style="flex:1;">
                <a href="@Url.Action("ChiTiet", "Product", new { id = sp.MaSanPham })" style="font-weight:600; color:#222;">@sp.TieuDe</a>
                <div style="color:#ef4444; font-weight:700; margin-top:4px;">@sp.Gia.ToString("N0") đ</div>
                <div style="font-size:12px; color:#9ca3af; margin-top:6px;">@sp.NgayDang.ToString("dd/MM/yyyy") · Tình trạng @sp.TinhTrangPhanTram%</div>
            </div>
            <div style="text-align:right; display:flex; flex-direction:column; gap:8px; align-items:flex-end;">
                <span style="background:@mau; color:#fff; padding:4px 12px; border-radius:20px; font-size:12px;">@chu</span>
                @if (sp.TrangThai != TrangThaiSanPham.DaBan && sp.TrangThai != TrangThaiSanPham.DaGo)
                {
                    using (Html.BeginForm("XoaTin", "Product", FormMethod.Post))
                    {
                        <input type="hidden" name="id" value="@sp.MaSanPham" />
                        <button type="button" class="btn btn-danger" style="padding:5px 14px; font-size:12px;"
                                onclick="moModal(this, 'Gỡ tin đăng?', 'Tin sẽ bị gỡ khỏi trang bán hàng.')">
                            Gỡ tin
                        </button>
                    }
                }
            </div>
        </div>
    }
}