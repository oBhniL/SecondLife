@model SecondLife.Models.ApplicationUser
@using SecondLife.Models
@{
    Layout = "~/Views/Shared/_LayoutProfile.cshtml";
    ViewBag.Title = "Xác thực người bán";
    ViewBag.Tab = "xt";
    ViewBag.HoTen = Model.HoTen;
}

<h2 style="color:#2ec4b6;">Xác thực người bán</h2>

@switch (Model.TinhTrangXacThuc)
{
    case TrangThaiXacThuc.DaDuyet:
        <div class="sl-alert sl-alert-ok">Tài khoản đã được xác thực. Bạn có thể đăng bán sản phẩm.</div>
        break;
    case TrangThaiXacThuc.DangCho:
        <div class="sl-alert" style="background:#fef3c7; color:#b45309; border:1px solid #fde68a;">
            Hồ sơ đang chờ admin duyệt. Nộp lúc @Model.NgayNopXacThuc?.ToString("dd/MM/yyyy HH:mm").
        </div>
        break;
    case TrangThaiXacThuc.TuChoi:
        <div class="sl-alert sl-alert-err">Hồ sơ bị từ chối. Lý do: @Model.LyDoTuChoi</div>
        <p style="color:#6b7280;">Vui lòng nộp lại hồ sơ.</p>
        break;
    default:
        <p style="color:#6b7280; margin-bottom:20px;">Để đăng bán sản phẩm, bạn cần nộp ảnh CCCD 2 mặt để admin xác minh.</p>
        break;
}

@if (Model.TinhTrangXacThuc == TrangThaiXacThuc.ChuaNop || Model.TinhTrangXacThuc == TrangThaiXacThuc.TuChoi)
{
    using (Html.BeginForm("NopXacThuc", "Profile", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        <div class="group" style="max-width:480px;">
            <label style="font-weight:600;">Số CCCD</label>
            <input type="text" name="SoCCCD" required style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:8px;" />
        </div>
        <div class="group" style="max-width:480px;">
            <label style="font-weight:600;">Ảnh CCCD mặt trước</label>
            <input type="file" name="AnhTruoc" accept="image/*" required />
        </div>
        <div class="group" style="max-width:480px;">
            <label style="font-weight:600;">Ảnh CCCD mặt sau</label>
            <input type="file" name="AnhSau" accept="image/*" required />
        </div>
        <button type="submit" class="btn btn-primary">Nộp hồ sơ</button>
    }
}