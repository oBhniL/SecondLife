<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - SecondLife</title>
    <link rel="stylesheet" href="~/Content/secondlife.css?v=3" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    @if (TempData["ThongBao"] != null)
    {
        <div class="toast" id="toast">@TempData["ThongBao"]</div>
    }

    <header class="sl-header">
        <div class="sl-header-inner">
            <a href="@Url.Action("Index", "Home")" class="sl-logo">
                <img src="~/images/second-hand.png" alt="Logo" /> SecondLife
            </a>
            <nav class="sl-nav" style="margin-left:auto;">
                <a href="@Url.Action("Index", "Home")">Trang chủ</a>
                <a href="@Url.Action("Index", "Product")">Sản phẩm</a>
                <a href="@Url.Action("DangTin", "Product")" class="btn-post"><i class="fa-solid fa-plus"></i> Đăng tin</a>
            </nav>
        </div>
    </header>

    <div class="pf-wrap">
        <div class="pf-side">
            @{
                var ten = ViewBag.HoTen as string ?? User.Identity.Name;
                var anhDD = ViewBag.AnhDaiDien as string;
            }
            <div class="pf-avatar">
                @if (!string.IsNullOrEmpty(anhDD))
                {
                    <img src="@(Url.Content(anhDD))?v=@DateTime.Now.Ticks" alt="avatar" />
                }
                else
                {
                    @ten.Substring(0, 1).ToUpper()
                }
            </div>
            <div class="pf-name">@ten</div>
            <div class="pf-mail">@User.Identity.Name</div>

            <div class="pf-menu">
                <a href="@Url.Action("Index", "Profile")" class="@(ViewBag.Tab == "info" ? "active" : "")">
                    <i class="fa-solid fa-user"></i> Thông tin cá nhân
                </a>
                <a href="@Url.Action("TinDaDang", "Profile")" class="@(ViewBag.Tab == "tin" ? "active" : "")">
                    <i class="fa-solid fa-tag"></i> Tin đã đăng
                </a>
                <a href="@Url.Action("DonHang", "Profile")" class="@(ViewBag.Tab == "don" ? "active" : "")">
                    <i class="fa-solid fa-box"></i> Đơn hàng của tôi
                </a>
                <a href="@Url.Action("XacThuc", "Profile")" class="@(ViewBag.Tab == "xt" ? "active" : "")">
                    <i class="fa-solid fa-id-card"></i> Xác thực người bán
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <div class="pf-divider"></div>
                    <a href="@Url.Action("Index", "Admin")"><i class="fa-solid fa-gauge"></i> Trang quản trị</a>
                }

                <div class="pf-divider"></div>
                <a href="@Url.Action("Login", "Home")" class="pf-logout">
                    <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                </a>
            </div>
        </div>

        <div class="pf-main">
            @RenderBody()
        </div>
    </div>

    <script>
        var t = document.getElementById("toast");
        if (t) setTimeout(function () { t.style.display = "none"; }, 3000);
    </script>
</body>
</html>